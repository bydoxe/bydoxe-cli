{
  "name": "@bydoxe/bydoxe-cli",
  "version": "0.1.1",
  "description": "Safe preview-first command-line companion for the BYDOXE Open API.",
  "license": "UNLICENSED",
  "type": "module",
  "author": "BYDOXE",
  "homepage": "https://github.com/bydoxe/bydoxe-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bydoxe/bydoxe-cli.git"
  },
  "bugs": {
    "url": "https://github.com/bydoxe/bydoxe-cli/issues"
  },
  "keywords": [
    "bydoxe",
    "crypto",
    "exchange",
    "open-api",
    "cli",
    "trading",
    "websocket",
    "agent"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "bydoxe": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "DISCLAIMER.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "catalog:generate": "npm run build && node scripts/generate-command-catalog.mjs",
    "catalog:check": "npm run build && node scripts/generate-command-catalog.mjs --check",
    "reference:generate": "npm run catalog:generate && node scripts/generate-command-reference.mjs",
    "reference:check": "node scripts/generate-command-reference.mjs --check",
    "summary:generate": "npm run catalog:generate && node scripts/generate-command-summary.mjs",
    "summary:check": "node scripts/generate-command-summary.mjs --check",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "smoke:readme": "npm run build && node scripts/smoke-readme-examples.mjs",
    "smoke:public-rest-live": "npm run build && node scripts/smoke-public-rest-live.mjs",
    "smoke:websocket-live": "npm run build && node scripts/smoke-websocket-public-live.mjs",
    "smoke:websocket-private-live": "npm run build && node scripts/smoke-websocket-private-live.mjs",
    "validate": "npm run typecheck && npm test && npm run catalog:check && npm run reference:check && npm run summary:check && npm run smoke:readme && npm run smoke:public-rest-live && npm run smoke:websocket-live && npm run smoke:websocket-private-live && node scripts/validate-project.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  }
}
